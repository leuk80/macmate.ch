---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  color: string;
}

const { title, description, href, icon, color } = Astro.props;
---

<a
  href={href}
  class="group block bg-white rounded-2xl border border-border p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
>
  <div class="w-12 h-12 rounded-xl flex items-center justify-center text-white mb-4" style={`background-color: ${color}`}>
    <Fragment set:html={icon} />
  </div>
  <h3 class="font-bold text-lg text-apple-black mb-2 group-hover:text-primary transition-colors">{title}</h3>
  <p class="text-apple-gray text-sm leading-relaxed">{description}</p>
</a>
