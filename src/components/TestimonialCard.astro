---
interface Props {
  name: string;
  quote: string;
  badge: string;
  stars?: number;
}

const { name, quote, badge, stars = 5 } = Astro.props;
---

<div class="bg-white rounded-2xl border border-border p-6">
  <div class="flex gap-0.5 mb-3">
    {Array.from({ length: stars }).map(() => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="#FF9F0A" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>
  <p class="text-apple-black text-sm leading-relaxed mb-4">„{quote}"</p>
  <div class="flex items-center justify-between">
    <span class="text-sm font-medium text-apple-black">{name}</span>
    <span class="text-xs font-medium text-apple-gray bg-surface px-2.5 py-1 rounded-full">{badge}</span>
  </div>
</div>
