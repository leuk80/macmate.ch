---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map(({ question, answer }) => (
    <details class="group bg-white border border-border rounded-xl">
      <summary class="flex items-center justify-between cursor-pointer px-6 py-4 text-sm font-semibold text-apple-black list-none">
        {question}
        <svg
          class="w-5 h-5 text-apple-lightgray transition-transform group-open:rotate-180"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </summary>
      <div class="px-6 pb-4 text-sm text-apple-gray leading-relaxed">
        {answer}
      </div>
    </details>
  ))}
</div>
