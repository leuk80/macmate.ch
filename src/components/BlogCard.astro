---
interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  readingTime: string;
  slug: string;
}

const { title, description, date, category, readingTime, slug } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('de-CH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block bg-white rounded-2xl border border-border overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
  <div class="bg-surface h-40 flex items-center justify-center">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#D2D2D7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
    </svg>
  </div>
  <div class="p-6">
    <div class="flex items-center gap-3 mb-3">
      <span class="text-xs font-semibold text-primary bg-primary-light px-2.5 py-1 rounded-full">{category}</span>
      <span class="text-xs text-apple-lightgray">{readingTime}</span>
    </div>
    <h2 class="font-bold text-lg text-apple-black mb-2 group-hover:text-primary transition-colors">{title}</h2>
    <p class="text-apple-gray text-sm leading-relaxed mb-3">{description}</p>
    <time class="text-xs text-apple-lightgray" datetime={date}>{formattedDate}</time>
  </div>
</a>
