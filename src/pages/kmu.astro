---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  { title: 'Geräte-Management', description: 'MDM via Apple Business Manager — alle Geräte zentral verwaltet.' },
  { title: 'Automatisches Onboarding', description: 'Neue Mitarbeiter erhalten ein fertig konfiguriertes Gerät in Minuten.' },
  { title: 'Backup & Recovery', description: 'Automatische Backups und schnelle Wiederherstellung im Ernstfall.' },
  { title: 'Sicherheit & Updates', description: 'Immer auf dem neusten Stand — ohne dass Sie sich darum kümmern müssen.' },
  { title: 'Monitoring & Proaktive Wartung', description: 'Wir erkennen Probleme, bevor sie auftreten.' },
  { title: 'Helpdesk', description: 'Anruf oder Chat — wir lösen Ihre IT-Probleme sofort.' },
];

const plans = [
  {
    name: 'Starter',
    devices: '1–5 Geräte',
    price: '39',
    responseTime: '8h',
    onsite: 'Nach Bedarf',
    onboarding: true,
    mdm: true,
    prioSupport: false,
    accountManager: false,
    featured: false,
  },
  {
    name: 'Growth',
    devices: '6–20 Geräte',
    price: '33',
    responseTime: '4h',
    onsite: '1x/Monat inkl.',
    onboarding: true,
    mdm: true,
    prioSupport: true,
    accountManager: false,
    featured: true,
  },
  {
    name: 'Scale',
    devices: '20+ Geräte',
    price: '29',
    responseTime: '2h',
    onsite: '2x/Monat inkl.',
    onboarding: true,
    mdm: true,
    prioSupport: true,
    accountManager: true,
    featured: false,
  },
];

const useCases = [
  {
    title: 'Kreativagentur',
    description: '12 Macs, alle auf dem neusten Stand, Backups laufen, Onboarding in 15 Minuten.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>',
  },
  {
    title: 'Startup',
    description: 'Von 3 auf 15 Geräte skaliert, ohne IT-Abteilung.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09Z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2Z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
  },
  {
    title: 'Architekturbüro',
    description: 'Netzwerk, Drucker, Plotter — alles läuft. Endlich.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>',
  },
];
---

<BaseLayout
  title="Managed Apple Services für KMU"
  description="Managed Apple Services für KMU in Zürich: Geräte-Management, Onboarding, Backup, Helpdesk. Ab CHF 29/Gerät pro Monat. Jetzt kostenloses IT-Audit anfragen."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-[#F3E8FF] to-white py-20 md:py-28">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <span class="inline-block bg-[#BF5AF2]/10 text-[#BF5AF2] text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
        Managed Services
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-apple-black mb-6">
        Managed Apple Services<br />für KMU in Zürich
      </h1>
      <p class="text-lg md:text-xl font-semibold text-white/80 mb-2">Ihre Apple-IT. Unser Job.</p>
      <p class="text-lg md:text-xl text-apple-gray max-w-2xl mx-auto mb-8">
        Wir übernehmen Ihre Apple-IT — damit Sie sich aufs Business konzentrieren können.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#audit"
          class="inline-flex items-center justify-center gap-2 bg-[#BF5AF2] text-white font-semibold px-8 py-3.5 rounded-full hover:bg-[#A347D1] transition-colors text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#BF5AF2]"
        >
          Kostenloses IT-Audit
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="#pricing"
          class="inline-flex items-center justify-center gap-2 bg-white text-apple-black font-semibold px-8 py-3.5 rounded-full border border-border hover:bg-surface transition-colors text-base"
        >
          Preise ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Was wir für Sie übernehmen</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Ihr Apple-Gerätepark, vollständig gemanagt — von der Einrichtung bis zum täglichen Support.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature) => (
          <div class="flex gap-4 p-6 rounded-2xl bg-surface">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[#BF5AF2]/10 flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#BF5AF2" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-apple-black mb-1">{feature.title}</h3>
              <p class="text-apple-gray text-sm leading-relaxed">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Transparente Preise</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Faire Monatspauschalen, keine versteckten Kosten. Skaliert mit Ihrem Unternehmen.
      </p>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {plans.map((plan) => (
          <div class:list={[
            'relative rounded-2xl p-8 flex flex-col',
            plan.featured
              ? 'bg-white border-2 border-[#BF5AF2] shadow-lg ring-1 ring-[#BF5AF2]/20'
              : 'bg-white border border-border'
          ]}>
            {plan.featured && (
              <span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[#BF5AF2] text-white text-xs font-semibold px-4 py-1 rounded-full">
                Beliebt
              </span>
            )}
            <h3 class="text-xl font-bold text-apple-black mb-1">{plan.name}</h3>
            <p class="text-sm text-apple-gray mb-4">{plan.devices}</p>
            <div class="mb-6">
              <span class="font-mono text-4xl font-bold text-apple-black">CHF {plan.price}</span>
              <span class="text-apple-gray text-sm">/Gerät/Mt.</span>
            </div>
            <ul class="space-y-3 mb-8 flex-1">
              <li class="flex items-center gap-3 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-apple-black">Reaktionszeit: <strong>{plan.responseTime}</strong></span>
              </li>
              <li class="flex items-center gap-3 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-apple-black">Vor-Ort-Support: <strong>{plan.onsite}</strong></span>
              </li>
              <li class="flex items-center gap-3 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-apple-black">Onboarding</span>
              </li>
              <li class="flex items-center gap-3 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span class="text-apple-black">MDM (Apple Business Manager)</span>
              </li>
              <li class="flex items-center gap-3 text-sm">
                {plan.prioSupport ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                ) : (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D2D2D7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                )}
                <span class:list={[plan.prioSupport ? 'text-apple-black' : 'text-apple-lightgray']}>Prio-Support</span>
              </li>
              <li class="flex items-center gap-3 text-sm">
                {plan.accountManager ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#30D158" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                ) : (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#D2D2D7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/></svg>
                )}
                <span class:list={[plan.accountManager ? 'text-apple-black' : 'text-apple-lightgray']}>Persönlicher Account Manager</span>
              </li>
            </ul>
            <a
              href="/kontakt"
              class:list={[
                'inline-flex items-center justify-center font-semibold px-6 py-3 rounded-full transition-colors text-center',
                plan.featured
                  ? 'bg-[#BF5AF2] text-white hover:bg-[#A347D1]'
                  : 'bg-surface text-apple-black hover:bg-border'
              ]}
            >
              Anfrage stellen
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Unsere Kunden</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Von der Kreativagentur bis zum Architekturbüro — wir betreuen Unternehmen jeder Grösse.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {useCases.map((useCase) => (
          <div class="bg-surface rounded-2xl p-8">
            <div class="w-12 h-12 rounded-2xl bg-[#BF5AF2]/10 flex items-center justify-center mb-4 text-[#BF5AF2]">
              <Fragment set:html={useCase.icon} />
            </div>
            <h3 class="text-xl font-bold text-apple-black mb-2">{useCase.title}</h3>
            <p class="text-apple-gray leading-relaxed">{useCase.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hilfreiche Artikel -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Hilfreiche Artikel</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Erfahren Sie mehr über Apple im Unternehmenseinsatz — in unserem Blog.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/blog/apple-fuer-kmu" class="rounded-2xl border border-border bg-white p-6 hover:shadow-lg transition-shadow group">
          <h3 class="font-bold text-lg text-apple-black group-hover:text-primary transition-colors">Apple für KMU — warum sich der Umstieg lohnt</h3>
          <p class="text-apple-gray text-sm leading-relaxed mt-2">Vorteile, Kostenvergleich und Praxistipps für den Wechsel zu Apple im Unternehmen.</p>
        </a>
        <a href="/blog/apple-business-plattform" class="rounded-2xl border border-border bg-white p-6 hover:shadow-lg transition-shadow group">
          <h3 class="font-bold text-lg text-apple-black group-hover:text-primary transition-colors">Apple Business — die neue All-in-One-Plattform</h3>
          <p class="text-apple-gray text-sm leading-relaxed mt-2">Wie Apple Business Manager, MDM und Zero-Touch Deployment zusammenspielen.</p>
        </a>
        <a href="/blog/apple-fuer-startups" class="rounded-2xl border border-border bg-white p-6 hover:shadow-lg transition-shadow group">
          <h3 class="font-bold text-lg text-apple-black group-hover:text-primary transition-colors">Apple für Startups — der ideale Tech-Stack</h3>
          <p class="text-apple-gray text-sm leading-relaxed mt-2">Warum immer mehr Startups auf Apple setzen und wie Sie profitieren.</p>
        </a>
      </div>
      <p class="text-apple-gray text-center mt-8">
        Schulungen für Ihr Team? Entdecken Sie unsere <a href="/workshops" class="text-primary hover:text-primary-dark underline">Apple Workshops</a>.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section id="audit" class="bg-[#BF5AF2] py-16 md:py-20">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Kostenloses IT-Audit Ihrer Apple-Umgebung
      </h2>
      <p class="text-white/80 text-lg max-w-2xl mx-auto mb-8">
        Wir analysieren Ihre aktuelle Apple-Infrastruktur und zeigen Ihnen, wie Sie Kosten sparen und die Produktivität steigern können — unverbindlich und kostenlos.
      </p>
      <a
        href="/kontakt"
        class="inline-flex items-center justify-center gap-2 bg-white text-[#BF5AF2] font-semibold px-8 py-3.5 rounded-full hover:bg-[#F3E8FF] transition-colors text-base"
      >
        Audit anfragen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Schema.org Service -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Managed Apple Services für KMU",
    "provider": {
      "@type": "LocalBusiness",
      "name": "MacMate",
      "url": "https://macmate.ch"
    },
    "areaServed": {
      "@type": "City",
      "name": "Zürich"
    },
    "description": "Professionelles Apple-Gerätemanagement für KMU in Zürich. MDM, Onboarding, Support und Monitoring ab CHF 29/Gerät/Monat.",
    "offers": {
      "@type": "AggregateOffer",
      "lowPrice": "29",
      "highPrice": "39",
      "priceCurrency": "CHF",
      "unitText": "pro Gerät/Monat"
    }
  })} />
</BaseLayout>
