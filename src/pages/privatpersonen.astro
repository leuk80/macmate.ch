---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingTier from '../components/PricingTier.astro';
import FaqAccordion from '../components/FaqAccordion.astro';

const problems = [
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>',
    title: 'Mac ist langsam',
    description: 'Dein Mac braucht ewig zum Starten oder Programme hängen? Wir finden die Ursache und machen ihn wieder schnell.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>',
    title: 'iCloud / Speicher voll',
    description: 'Speicher voll, iCloud-Sync spinnt? Wir räumen auf und richten alles richtig ein.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>',
    title: 'Drucker / WLAN funktioniert nicht',
    description: 'Drucker druckt nicht, WLAN ist instabil? Wir bringen dein Netzwerk in Ordnung.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/><path d="m9 10 3-3 3 3"/></svg>',
    title: 'Daten umziehen',
    description: 'Neuer Mac oder iPhone? Wir übertragen alle Daten, Apps und Einstellungen — ohne Verlust.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
    title: 'Passwort / Account-Probleme',
    description: 'Apple-ID gesperrt, Passwort vergessen? Wir helfen dir, den Zugang wiederherzustellen.',
  },
  {
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>',
    title: 'Backup einrichten',
    description: 'Time Machine, iCloud oder externe Festplatte — wir richten dein Backup ein, damit nichts verloren geht.',
  },
];

const faqItems = [
  {
    question: 'Was kostet ein Einsatz?',
    answer: 'Unsere Pakete starten bei CHF 69 für einen Quick-Fix (30 Min). Der Standard-Einsatz (60 Min) kostet CHF 129 und der Deep-Dive (2 Std) CHF 229. Die Anfahrt innerhalb der Stadt Zürich ist inklusive.',
  },
  {
    question: 'Wie schnell könnt ihr kommen?',
    answer: 'In der Regel sind wir innerhalb von 2 Stunden bei dir — oft sogar schneller. Bei dringenden Fällen ruf uns einfach an und wir finden die schnellste Lösung.',
  },
  {
    question: 'Bezahlung — Twint, Karte, Rechnung?',
    answer: 'Wir akzeptieren Twint, Kredit-/Debitkarte und Barzahlung. Auf Wunsch stellen wir auch gerne eine Rechnung aus.',
  },
  {
    question: 'Was, wenn das Problem nicht gelöst werden kann?',
    answer: 'Sollten wir dein Problem wider Erwarten nicht lösen können, zahlst du nur die Diagnosepauschale. Transparenz und Fairness sind uns wichtig.',
  },
  {
    question: 'Repariert ihr auch Hardware?',
    answer: 'Wir fokussieren uns auf Software-Support, Einrichtung und Schulung. Bei Hardware-Problemen beraten wir dich gerne und vermitteln an einen vertrauenswürdigen Reparatur-Partner.',
  },
];
---

<BaseLayout
  title="Apple-Support für Privatpersonen — MacMate · Apple Support Zürich"
  description="Persönlicher Apple-Support bei dir zu Hause in Zürich. Mac langsam, iCloud voll, Daten umziehen — wir helfen schnell, verständlich und fair. Ab CHF 69."
  canonical="https://macmate.ch/privatpersonen"
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-light to-white py-20 md:py-28">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-apple-black mb-6">
        Persönlicher Apple-Support<br />— bei dir zu Hause
      </h1>
      <p class="text-lg md:text-xl text-apple-gray max-w-2xl mx-auto mb-8">
        Mac langsam? iPhone spinnt? Wir kommen vorbei oder helfen remote. Verständlich, geduldig, fair.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#termin"
          class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-8 py-3.5 rounded-full hover:bg-primary-dark transition-colors text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          Jetzt Termin buchen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="#preise"
          class="inline-flex items-center justify-center gap-2 bg-white text-apple-black font-semibold px-8 py-3.5 rounded-full border border-border hover:bg-surface transition-colors text-base"
        >
          Preise ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- Häufige Probleme -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Häufige Probleme</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Kommt dir etwas davon bekannt vor? Wir haben die Lösung.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {problems.map(({ icon, title, description }) => (
          <div class="bg-white border border-border rounded-2xl p-6 hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary mb-4">
              <Fragment set:html={icon} />
            </div>
            <h3 class="font-bold text-lg text-apple-black mb-2">{title}</h3>
            <p class="text-apple-gray text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Preise -->
  <section id="preise" class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Unsere Preise</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Transparent und fair — wähle das Paket, das zu deinem Problem passt.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <PricingTier
          name="Quick-Fix"
          duration="30 Minuten"
          price="CHF 69"
          description="Ein einzelnes Problem schnell und unkompliziert lösen. Ideal für kleine Fragen und schnelle Hilfe."
        />
        <PricingTier
          name="Standard"
          duration="60 Minuten"
          price="CHF 129"
          description="Gründliche Diagnose, Lösung und hilfreiche Tipps für den Alltag. Unser beliebtestes Paket."
          featured={true}
        />
        <PricingTier
          name="Deep-Dive"
          duration="2 Stunden"
          price="CHF 229"
          description="Umfassende Analyse, Setup-Optimierung und persönliche Schulung. Für alle, die das Maximum rausholen wollen."
        />
      </div>
      <p class="text-sm text-apple-lightgray text-center mt-8">
        Anfahrt in der Stadt Zürich inklusive. Ausserhalb: CHF 1/km.
      </p>
    </div>
  </section>

  <!-- Terminbuchung -->
  <section id="termin" class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Termin buchen</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Wähle einen passenden Zeitpunkt — wir melden uns bei dir.
      </p>
      <!-- TODO: Cal.com Embed (client:visible Island) -->
      <div class="max-w-2xl mx-auto bg-surface border border-border rounded-2xl p-8 md:p-12 text-center">
        <div class="w-16 h-16 rounded-2xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-6">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
            <line x1="16" x2="16" y1="2" y2="6"/>
            <line x1="8" x2="8" y1="2" y2="6"/>
            <line x1="3" x2="21" y1="10" y2="10"/>
          </svg>
        </div>
        <p class="text-apple-gray mb-6">
          Die Online-Terminbuchung wird hier eingebunden. In der Zwischenzeit erreichst du uns direkt:
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:+41786089965"
            class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-full hover:bg-primary-dark transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Anrufen
          </a>
          <a
            href="https://wa.me/41786089965"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#25D366] text-white font-semibold px-6 py-3 rounded-full hover:bg-[#1da851] transition-colors"
          >
            WhatsApp
          </a>
          <a
            href="/kontakt"
            class="inline-flex items-center justify-center gap-2 bg-white text-apple-black font-semibold px-6 py-3 rounded-full border border-border hover:bg-surface transition-colors"
          >
            Kontaktformular
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Häufige Fragen</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Hier findest du Antworten auf die wichtigsten Fragen.
      </p>
      <div class="max-w-2xl mx-auto">
        <FaqAccordion items={faqItems} />
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-primary py-16 md:py-20">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Bereit? Wir helfen dir gerne.</h2>
      <p class="text-primary-light text-lg mb-8">Kostenlose Erstberatung — ruf an, schreib uns oder buche direkt.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+41786089965"
          class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-6 py-3 rounded-full hover:bg-primary-light transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Anrufen
        </a>
        <a
          href="https://wa.me/41786089965"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-6 py-3 rounded-full hover:bg-primary-light transition-colors"
        >
          WhatsApp
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-6 py-3 rounded-full hover:bg-primary-light transition-colors"
        >
          Termin buchen
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
