---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Die gewünschte Seite konnte nicht gefunden werden."
>
  <section class="py-20 md:py-32">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <p class="text-6xl md:text-8xl font-extrabold text-primary mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-apple-black mb-4">Seite nicht gefunden</h1>
      <p class="text-apple-gray text-lg max-w-md mx-auto mb-8">
        Die gewünschte Seite existiert leider nicht oder wurde verschoben.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-8 py-3.5 rounded-full hover:bg-primary-dark transition-colors text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          Zur Startseite
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center gap-2 border-2 border-primary text-primary font-semibold px-8 py-3.5 rounded-full hover:bg-primary-light transition-colors text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
