---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = new Date(post.data.date).toLocaleDateString('de-CH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description} ogType="article">
  <!-- BlogPosting Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.date,
    "author": {
      "@type": "Person",
      "name": "Kim Engels",
    },
    "image": "https://macmate.ch/og-image.jpg",
    "dateModified": post.data.date,
    "publisher": {
      "@type": "Organization",
      "name": "MacMate",
    },
    "url": Astro.url.href,
  })} />

  <article class="py-16 md:py-24">
    <div class="mx-auto max-w-[720px] px-4 sm:px-6">
      <div class="mb-8">
        <a href="/blog" class="text-sm text-primary hover:text-primary-dark transition-colors inline-flex items-center gap-1 mb-6">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          Zurück zum Blog
        </a>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-semibold text-primary bg-primary-light px-2.5 py-1 rounded-full">{post.data.category}</span>
          <span class="text-xs text-apple-lightgray">{post.data.readingTime}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-apple-black mb-4">{post.data.title}</h1>
        <time class="text-sm text-apple-lightgray" datetime={post.data.date}>{formattedDate}</time>
      </div>

      <div class="prose prose-lg max-w-none text-apple-black
        [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-apple-black [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-apple-black [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-apple-gray [&_p]:leading-relaxed [&_p]:mb-4
        [&_a]:text-primary [&_a]:underline [&_a]:hover:text-primary-dark
        [&_strong]:text-apple-black [&_strong]:font-semibold
        [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:text-apple-gray
        [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:text-apple-gray
        [&_li]:mb-1
        [&_table]:w-full [&_table]:text-sm [&_table]:mb-6
        [&_th]:text-left [&_th]:py-2 [&_th]:px-3 [&_th]:bg-surface [&_th]:font-semibold [&_th]:text-apple-black
        [&_td]:py-2 [&_td]:px-3 [&_td]:border-t [&_td]:border-border [&_td]:text-apple-gray
        [&_code]:bg-surface [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-sm [&_code]:font-mono
      ">
        <Content />
      </div>

      <!-- CTA -->
      <div class="mt-12 bg-surface rounded-2xl p-8 text-center">
        <h2 class="font-bold text-xl text-apple-black mb-2">Brauchst du Hilfe?</h2>
        <p class="text-apple-gray text-sm mb-4">Wir helfen dir gerne — persönlich, schnell und fair.</p>
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-full hover:bg-primary-dark transition-colors">
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
