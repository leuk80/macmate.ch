---
import BaseLayout from '../layouts/BaseLayout.astro';
import PricingTier from '../components/PricingTier.astro';

const workshops = [
  {
    title: 'iPhone & iPad Basics',
    audience: 'Einsteiger / Senioren',
    duration: '2 Stunden',
    price: 'CHF 89',
    description: 'Lerne die wichtigsten Funktionen deines iPhones oder iPads kennen — von der Bedienung bis zu den besten Apps.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="12" height="20" x="6" y="2" rx="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>',
  },
  {
    title: 'Mac-Produktivität',
    audience: 'Freelancer / Kreative',
    duration: '3 Stunden',
    price: 'CHF 129',
    description: 'Keyboard-Shortcuts, Automator, Spotlight und mehr — arbeite schneller und effizienter mit deinem Mac.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>',
  },
  {
    title: 'Sicherheit & Privacy',
    audience: 'Alle',
    duration: '2 Stunden',
    price: 'CHF 89',
    description: 'Schütze deine Daten — Passwörter, Zwei-Faktor-Authentifizierung, sicheres Surfen und mehr.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
  },
  {
    title: 'Apple im Team',
    audience: 'KMU-Teams',
    duration: '4 Stunden',
    price: 'CHF 149/Person',
    description: 'Zusammenarbeit mit Apple-Geräten im Team — iCloud, geteilte Kalender, Keynote, und mehr.',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
];

const formats = [
  {
    title: '1:1 Coaching',
    description: 'Individuell, bei dir zu Hause oder remote. Wir gehen genau auf deine Fragen ein.',
    price: 'CHF 129/h',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
  },
  {
    title: 'Kleingruppe',
    description: 'Maximal 6 Teilnehmer — im Coworking Space in Zürich. Lernen in entspannter Atmosphäre.',
    price: 'Gemäss Katalog',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
  {
    title: 'Firmen-Workshop',
    description: 'Bei euch vor Ort, massgeschneidert auf eure Bedürfnisse. Ideal für Team-Onboarding.',
    price: 'Auf Anfrage',
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M12 14h.01"/><path d="M16 10h.01"/><path d="M16 14h.01"/><path d="M8 10h.01"/><path d="M8 14h.01"/></svg>',
  },
];

const nextDates = [
  { workshop: 'iPhone & iPad Basics', date: 'Samstag, 12. April 2026, 10:00 – 12:00', spots: 4 },
  { workshop: 'Mac-Produktivität', date: 'Samstag, 19. April 2026, 09:00 – 12:00', spots: 3 },
  { workshop: 'Sicherheit & Privacy', date: 'Mittwoch, 23. April 2026, 18:00 – 20:00', spots: 6 },
  { workshop: 'Apple im Team', date: 'Freitag, 2. Mai 2026, 09:00 – 13:00', spots: 5 },
];
---

<BaseLayout
  title="Apple Workshops & Schulungen in Zürich"
  description="Praxisnahe Apple-Workshops in Zürich: iPhone & iPad Basics, Mac-Produktivität, Sicherheit & Privacy. Für Einsteiger, Profis und Teams."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-primary-light to-white py-20 md:py-28">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-apple-black mb-6">
        Apple Workshops &amp; Schulungen<br />in Zürich
      </h1>
      <p class="text-lg md:text-xl text-apple-gray max-w-2xl mx-auto mb-8">
        Praxisnahe Workshops für Einsteiger, Umsteiger und Teams. Verständlich erklärt, sofort anwendbar.
      </p>
      <a
        href="#termine"
        class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-8 py-3.5 rounded-full hover:bg-primary-dark transition-colors text-base focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Nächste Termine ansehen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- Workshop-Katalog -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Workshop-Katalog</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Wähle den Workshop, der zu dir passt — vom Einsteiger-Kurs bis zum Team-Training.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {workshops.map((w) => (
          <div class="rounded-2xl border border-border bg-white p-6 hover:shadow-lg transition-shadow">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-primary-light flex items-center justify-center text-primary" set:html={w.icon} />
              <div class="flex-1">
                <h3 class="font-bold text-lg text-apple-black">{w.title}</h3>
                <p class="text-sm text-apple-gray mt-1">{w.audience}</p>
              </div>
            </div>
            <p class="text-apple-gray text-sm leading-relaxed mt-4">{w.description}</p>
            <div class="flex items-center justify-between mt-5 pt-5 border-t border-border">
              <div class="flex items-center gap-4 text-sm text-apple-gray">
                <span class="flex items-center gap-1">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {w.duration}
                </span>
              </div>
              <span class="font-mono font-bold text-lg text-apple-black">{w.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formate -->
  <section class="bg-surface py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Formate</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Ob einzeln, in der Gruppe oder als Team — wir haben das passende Format für dich.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {formats.map((f) => (
          <div class="rounded-2xl border border-border bg-white p-6 text-center">
            <div class="w-14 h-14 rounded-xl bg-primary-light flex items-center justify-center text-primary mx-auto mb-4" set:html={f.icon} />
            <h3 class="font-bold text-lg text-apple-black">{f.title}</h3>
            <p class="text-apple-gray text-sm leading-relaxed mt-2 mb-4">{f.description}</p>
            <span class="inline-block font-mono font-bold text-primary">{f.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nächste Termine -->
  <section id="termine" class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-apple-black text-center mb-4">Nächste Termine</h2>
      <p class="text-apple-gray text-center max-w-xl mx-auto mb-12">
        Sichere dir deinen Platz — die Gruppen sind bewusst klein gehalten.
      </p>
      <!-- TODO: Termine durch echte Daten ersetzen -->
      <div class="space-y-4 max-w-2xl mx-auto">
        {nextDates.map((t) => (
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 rounded-2xl border border-border bg-white p-5">
            <div>
              <h3 class="font-bold text-apple-black">{t.workshop}</h3>
              <p class="text-sm text-apple-gray mt-1">{t.date}</p>
              <p class="text-xs text-apple-lightgray mt-0.5">Noch {t.spots} Plätze frei</p>
            </div>
            <a
              href="/kontakt"
              class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-5 py-2.5 rounded-full hover:bg-primary-dark transition-colors text-sm whitespace-nowrap focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              Anmelden
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-primary py-16 md:py-20">
    <div class="mx-auto max-w-[var(--container-content)] px-4 sm:px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Individueller Workshop gewünscht?</h2>
      <p class="text-primary-light text-lg mb-8">Wir stellen dir ein massgeschneidertes Programm zusammen — für dich oder dein Team.</p>
      <a
        href="/kontakt"
        class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-8 py-3.5 rounded-full hover:bg-primary-light transition-colors text-base"
      >
        Jetzt anfragen
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
